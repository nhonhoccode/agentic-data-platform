# Core app
APP_ENV=dev
APP_API_KEY=change-me
APP_PORT=8000
LOG_LEVEL=INFO

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=olist
POSTGRES_USER=olist
POSTGRES_PASSWORD=olist
POSTGRES_READONLY_USER=olist_ro
POSTGRES_READONLY_PASSWORD=olist_ro
DB_ENFORCE_READONLY_ROLE=true
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=8
DB_STATEMENT_TIMEOUT_MS=120000

# Paths
DATA_DIR=./data

# Optional LLM (hybrid local-first)
# Values: none | openai | gemini | deepseek | self_host | openai_compatible
LLM_PROVIDER=none
LLM_ENABLE_THINKING=false
TEMPERATURE=0

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
BASE_URL=
MODEL_API_BASE=

# Gemini
# Note: Free-tier quota cho gemini-2.0-flash đã EOL trên nhiều key cũ.
# Recommend: dùng MODEL_API_BASE=gemini-2.5-flash khi LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_KEY_BACKUP=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenRouter (multi-model proxy: Claude, GPT-4, Llama, Gemini Pro via single endpoint)
# To use: LLM_PROVIDER=openrouter, OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Self-host LLM (Qwen via OpenAI-compatible endpoint)
# Example:
#   LLM_PROVIDER=self_host
#   BASE_URL=http://100.108.110.17:8000/v1
#   MODEL_API_BASE=Qwen/Qwen3.6-27B-FP8
#   OPENAI_API_KEY=nokey

# LangSmith observability (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=olist-ai-platform
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Qdrant vector database (RAG)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_SCHEMA=schema_metadata
QDRANT_COLLECTION_GLOSSARY=business_terms
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Airflow
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Cloudflared quick tunnel (auto domain in logs)
# Example domain after startup: https://xxxx.trycloudflare.com
CLOUDFLARED_COMMAND=tunnel --no-autoupdate --url http://api:8000

# Named tunnel mode example (custom domain, stable):
# CLOUDFLARED_COMMAND=tunnel --no-autoupdate run --token <your_tunnel_token>
# Then add "Published application route" in Cloudflare dashboard:
#   hostname: api.votrongnhon.cloud
#   service:  http://api:8000
#
# Security requirement for public exposure:
# - Enable Cloudflare Access policy for API/UI/Airflow routes.
